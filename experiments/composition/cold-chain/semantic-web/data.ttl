@prefix ex: <https://example.org/cold-chain/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:shipment_102 a geo:Feature ;
  ex:initialState ex:Safe .

ex:ColdZone a geo:Feature ;
  geo:hasGeometry ex:ColdZoneGeometry .

ex:ColdZoneGeometry a geo:Geometry ;
  geo:asWKT "<http://www.opengis.net/def/crs/OGC/1.3/CRS84> POLYGON ((0 0, 10 0, 10 10, 0 10, 0 0))"^^geo:wktLiteral .

ex:observation_0 a sosa:Observation ;
  sosa:hasFeatureOfInterest ex:shipment_102 ;
  sosa:resultTime "2026-07-19T08:00:00Z"^^xsd:dateTimeStamp ;
  sosa:phenomenonTime ex:instant_0 ;
  sosa:hasResult ex:result_0 .
ex:instant_0 a time:Instant ;
  time:inXSDDateTimeStamp "2026-07-19T08:00:00Z"^^xsd:dateTimeStamp .
ex:result_0 a geo:Geometry ;
  geo:asWKT "<http://www.opengis.net/def/crs/OGC/1.3/CRS84> POINT (5 5)"^^geo:wktLiteral .

ex:observation_1 a sosa:Observation ;
  sosa:hasFeatureOfInterest ex:shipment_102 ;
  sosa:resultTime "2026-07-19T08:05:00Z"^^xsd:dateTimeStamp ;
  sosa:phenomenonTime ex:instant_1 ;
  sosa:hasResult ex:result_1 .
ex:instant_1 a time:Instant ;
  time:inXSDDateTimeStamp "2026-07-19T08:05:00Z"^^xsd:dateTimeStamp .
ex:result_1 a geo:Geometry ;
  geo:asWKT "<http://www.opengis.net/def/crs/OGC/1.3/CRS84> POINT (12 5)"^^geo:wktLiteral .

