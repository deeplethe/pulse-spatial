  sosa:hasFeatureOfInterest ex:shipment_102 ;
  sosa:resultTime "2026-07-19T08:12:00Z"^^xsd:dateTimeStamp ;
  sosa:phenomenonTime ex:instant_2 ;
  sosa:hasResult ex:result_2 .
ex:instant_2 a time:Instant ;
  time:inXSDDateTimeStamp "2026-07-19T08:12:00Z"^^xsd:dateTimeStamp .
ex:result_2 a geo:Geometry ;
  geo:asWKT "<http://www.opengis.net/def/crs/OGC/1.3/CRS84> POINT (5 5)"^^geo:wktLiteral .

ex:observation_3 a sosa:Observation ;
  sosa:hasFeatureOfInterest ex:shipment_102 ;
  sosa:resultTime "2026-07-19T08:20:00Z"^^xsd:dateTimeStamp ;
  sosa:phenomenonTime ex:instant_3 ;
  sosa:hasResult ex:result_3 .
ex:instant_3 a time:Instant ;
